services:
  db:
    image: postgres:15-alpine
    container_name: devops_db_prod
    restart: unless-stopped
    environment:
      POSTGRES_DB: devops_platform
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d devops_platform"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - app_network

  backend:
    image: ghcr.io/${GHCR_OWNER}/devops-platform-backend:${IMAGE_TAG}
    container_name: backend_prod
    restart: unless-stopped
    command: ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
    expose:
      - "8000"
    environment:
      - DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/devops_platform
      - ENVIRONMENT=production
      - SECRET_KEY=${SECRET_KEY}
      - APP_VERSION=${APP_VERSION}
      - BUILD_SHA=${BUILD_SHA}
      - IMAGE_TAG=${IMAGE_TAG}
      - BUILD_DATE=${BUILD_DATE}
      - BUILD_ID=${BUILD_ID}
      - CONTAINER_REGISTRY=${CONTAINER_REGISTRY}
      - INCIDENT_ASSISTANT_USE_OLLAMA=${INCIDENT_ASSISTANT_USE_OLLAMA}
      - OLLAMA_BASE_URL=${OLLAMA_BASE_URL}
      - OLLAMA_MODEL=${OLLAMA_MODEL}
      - OLLAMA_TIMEOUT_SECONDS=${OLLAMA_TIMEOUT_SECONDS}
    depends_on:
      db:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    networks:
      - app_network

  frontend:
    image: ghcr.io/${GHCR_OWNER}/devops-platform-frontend:${IMAGE_TAG}
    container_name: frontend_prod
    restart: unless-stopped
    expose:
      - "80"
    depends_on:
      backend:
        condition: service_healthy
    networks:
      - app_network

  monitor-worker:
    image: ghcr.io/${GHCR_OWNER}/devops-platform-monitor-worker:${IMAGE_TAG}
    container_name: monitor_worker_prod
    restart: unless-stopped
    command: ["python", "-m", "backend.monitor_worker"]
    expose:
      - "9000"
    environment:
      - DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/devops_platform
      - ENVIRONMENT=production
      - MONITOR_INTERVAL_SECONDS=60
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    depends_on:
      db:
        condition: service_healthy
      backend:
        condition: service_healthy
      frontend:
        condition: service_healthy
      nginx:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9000/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    networks:
      - app_network

  action-runner:
    image: ghcr.io/${GHCR_OWNER}/devops-platform-monitor-worker:${IMAGE_TAG}
    container_name: action_runner_prod
    restart: unless-stopped
    command: ["python", "-m", "backend.monitor_worker"]
    environment:
      - DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/devops_platform
      - ENVIRONMENT=production
      - MONITOR_INTERVAL_SECONDS=10
      - MONITOR_PROBES_ENABLED=false
      - MONITOR_HEALTH_PORT=9100
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    depends_on:
      db:
        condition: service_healthy
      backend:
        condition: service_healthy
    networks:
      - app_network

  nginx:
    image: nginx:1.27-alpine
    container_name: nginx_prod
    restart: unless-stopped
    depends_on:
      - backend
      - frontend
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./prod.conf:/etc/nginx/conf.d/default.conf:ro
      - ./ssl:/etc/ssl/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1/health >/dev/null || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
    networks:
      - app_network

  prometheus:
    image: prom/prometheus:v2.51.2
    container_name: prometheus_prod
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.retention.time=7d"
      - "--storage.tsdb.path=/prometheus"
      - "--web.external-url=/prometheus/"
      - "--web.route-prefix=/prometheus/"
    expose:
      - "9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    depends_on:
      - backend
      - monitor-worker
    networks:
      - app_network

  grafana:
    image: grafana/grafana:10.4.3
    container_name: grafana_prod
    restart: unless-stopped
    expose:
      - "3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD}
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_ANALYTICS_REPORTING_ENABLED=false
      - GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s/grafana/
      - GF_SERVER_SERVE_FROM_SUB_PATH=true
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
    depends_on:
      - prometheus
    networks:
      - app_network

volumes:
  postgres_data:
  prometheus_data:
  grafana_data:

networks:
  app_network:
    driver: bridge
