# Cloudflare DDNS updater for local.kydyrov.dev
# Copy this file to /etc/default/cloudflare-ddns on the home VM and fill in your values.

CF_API_TOKEN=
CF_ZONE_NAME=kydyrov.dev
CF_RECORD_NAME=local.kydyrov.dev
CF_RECORD_TYPE=A
CF_TTL=1
CF_PROXIED=false
CF_PUBLIC_IP_URL=https://api.ipify.org?format=json
CF_TIMEOUT_SECONDS=15
