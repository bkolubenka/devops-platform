{
  "id": null,
  "uid": "devops-platform-overview",
  "title": "DevOps Platform Overview",
  "tags": ["devops-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Request Rate (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Error Rate (5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 Request Latency (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Incidents Created (1h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(incidents_created_total[1h]))",
          "legendFormat": "incidents"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Requests by Endpoint (rate 5m)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (endpoint) (rate(http_requests_total[5m]))",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Service Probe Success Rate (5m)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(service_probe_success_total[5m]) / (rate(service_probe_success_total[5m]) + rate(service_probe_failure_total[5m]) + 0.0001)",
          "legendFormat": "{{ service_name }}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Service Probe Latency p95 (5m)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(service_probe_latency_seconds_bucket[5m])))",
          "legendFormat": "{{ service_name }} p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Incident Assistant Mode (rate 5m)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (mode) (rate(incident_assistant_requests_total[5m]))",
          "legendFormat": "{{ mode }}"
        }
      ]
    }
  ]
}
